# Environment (local or cloud)
ENV=local

# FastAPI Security
JWT_SECRET=super-secret-key-change-it-in-production-1234567890
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API Key (Get from: https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_FREE_GEMINI_API_KEY

# Cloud Mode Configurations (only needed if ENV=cloud)
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# QDRANT_URL=https://xxxx.gcp.qdrant.io:6333
# QDRANT_API_KEY=xxxxxx
# STORAGE_TYPE=supabase
# SUPABASE_URL=https://xxxxxx.supabase.co
# SUPABASE_KEY=xxxxxx
# SUPABASE_BUCKET=pdfs
